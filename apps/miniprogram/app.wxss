page {
  background: linear-gradient(145deg, #f4fbff, #eef7f2);
  color: #142534;
  font-family: "PingFang SC", "Noto Sans SC", sans-serif;
}

.container {
  padding: 24rpx;
}

.panel {
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(56, 98, 128, 0.18);
  border-radius: 22rpx;
  padding: 20rpx;
  margin-bottom: 18rpx;
}

.panel-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 14rpx;
}

.hint {
  color: #567184;
  font-size: 24rpx;
}

.btn {
  background: linear-gradient(135deg, #1ea59a, #3a7ce1);
  color: #fff;
  border-radius: 16rpx;
  padding: 10rpx 20rpx;
  font-size: 26rpx;
  border: none;
}

.btn-ghost {
  background: #ffffff;
  color: #1e6173;
  border: 1rpx solid rgba(30, 97, 115, 0.22);
}
