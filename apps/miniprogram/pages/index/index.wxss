.card {
  border: 1rpx solid rgba(37, 82, 112, 0.18);
  border-radius: 16rpx;
  padding: 14rpx;
  margin-top: 12rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: rgba(255, 255, 255, 0.84);
}

.name {
  font-size: 28rpx;
  font-weight: 700;
}

.numbers {
  text-align: right;
  font-size: 24rpx;
  color: #27495e;
}

.heat-row {
  margin-top: 10rpx;
  display: flex;
  justify-content: space-between;
  border-bottom: 1rpx dashed rgba(35, 75, 101, 0.2);
  padding-bottom: 8rpx;
}

.heat-name {
  font-size: 25rpx;
}

.heat-value {
  font-size: 25rpx;
  font-weight: 700;
  color: #197f76;
}
